# -----------------------------
# API Keys
# -----------------------------
GOOGLE_API_KEY=
GROQ_API_KEY=

# -----------------------------
# LLM Configuration
# -----------------------------
# Set to true to use a local Ollama model.
# When false, the application uses the provider below.
USE_LOCAL_LLM=false

# Options: groq, gemini
DEFAULT_MODEL_PROVIDER=groq

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:latest

# Gemini
GEMINI_MODEL=gemini-2.5-flash

# Groq
GROQ_MODEL=llama-3.1-8b-instant

# -----------------------------
# Embeddings
# -----------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2

# -----------------------------
# Storage
# -----------------------------
CHROMA_DB_PATH=data/chroma_db
PDF_STORAGE_PATH=data/pdfs
PAGES_STORE_PATH=data/pages_store

# -----------------------------
# Retrieval
# -----------------------------
TOP_K=10
TOP_K_CHATALL=5
RERANKING_SAMPLE_SIZE=30

# -----------------------------
# Reranking
# -----------------------------
# Options:
# none
# cross_encoder
# llm_local
# llm_api
RERANKER_TYPE=cross_encoder

# Used only when RERANKER_TYPE=llm_api
# Options: gemini, groq
RERANKER_API_PROVIDER=gemini

# Used only when RERANKER_TYPE=cross_encoder
CROSS_ENCODER_MODEL=BAAI/bge-reranker-v2-m3

# -----------------------------
# Chunking
# -----------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# -----------------------------
# Conversation Memory
# -----------------------------
MAX_HISTORY=10